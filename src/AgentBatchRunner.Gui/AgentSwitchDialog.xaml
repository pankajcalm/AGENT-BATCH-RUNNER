<Window x:Class="AgentBatchRunner.Gui.AgentSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Pending Agent"
        Width="480"
        Height="270"
        MinWidth="440"
        MinHeight="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14" TextWrapping="Wrap"
                   Text="The switch applies only to prompts that have not started. The current process and completed prompts are unchanged." />
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Current agent" />
        <ComboBox x:Name="SourceAgentBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" SelectionChanged="SelectionChanged" />
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Replacement agent" />
        <ComboBox x:Name="ReplacementAgentBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" SelectionChanged="SelectionChanged" />
        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,10" FontWeight="SemiBold" Text="Scope" />
        <TextBlock x:Name="ScopeText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />
        <CheckBox x:Name="RetryRateLimitedTaskBox" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,12"
                  Content="Continue the stopped rate-limited task with the replacement agent" />

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="88" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
            <Button x:Name="ConfirmButton" Width="100" IsDefault="True" Click="ConfirmClick" Content="Confirm" />
        </StackPanel>
    </Grid>
</Window>
