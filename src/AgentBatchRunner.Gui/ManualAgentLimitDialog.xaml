<Window x:Class="AgentBatchRunner.Gui.ManualAgentLimitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Agent Limit Manually"
        SizeToContent="Height"
        Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Agent" />
        <ComboBox x:Name="AgentComboBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
            <ComboBoxItem Content="claude" />
            <ComboBoxItem Content="codex" />
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Blocked until (date)" />
        <DatePicker x:Name="BlockedUntilDatePicker" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Blocked until (time)" />
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Orientation="Horizontal">
            <TextBox x:Name="BlockedUntilTimeTextBox" Width="90" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#6B7280" Text="24h, e.g. 13:27" />
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" FontWeight="SemiBold" Text="Reason" />
        <TextBox x:Name="ReasonTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" />

        <TextBlock x:Name="ValidationTextBlock"
                   Grid.Row="4"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,0,0,10"
                   Foreground="#B00020"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Width="90" Margin="0,0,8,0" IsDefault="True" Content="Save" Click="OnSaveClick" />
            <Button x:Name="CancelButton" Width="90" IsCancel="True" Content="Cancel" Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
